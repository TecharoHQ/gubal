# Chrome era image — Ubuntu 24.04 (Chrome major 120-139, ~2024-2025).
#
# The base image is chosen to be contemporary with the Chrome build so the deb's
# declared dependencies resolve against packages that actually existed then.
#
# Layering, fastest-to-rebuild first. Everything above the CHROME_DEB_URL ARG is
# identical for every Chrome version in this era, so Docker serves it from cache and
# a new Chrome build only re-runs the final deb layer:
#   1. base tooling + fonts + socat
#   2. Chrome's full shared-library dependency closure (the slow one — see below)
#   3. tini, the runtime user, the entrypoint
#   4. the actual, per-version Chrome deb   <-- only this re-runs per version
#
# Build:
#   docker build -f docker/Dockerfile.ubuntu-24.04 \
#     --build-arg CHROME_DEB_URL=https://chrome-archive.t3.tigrisfiles.io/chrome/120/google-chrome-stable_120.0.6099.109-1_amd64.deb \
#     --build-arg CHROME_DEB_SHA256=<sha256> \
#     -t ghcr.io/techarohq/gubal/chrome:120 .
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Base tooling — curl/ca-certificates fetch the debs below, socat is the CDP bridge,
# and the fonts render CJK/emoji. Version-independent, so it stays cached.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      socat \
      fonts-liberation \
      fonts-noto-cjk \
      fonts-noto-color-emoji; \
    rm -rf /var/lib/apt/lists/*

# Warm Chrome's full shared-library dependency closure (libnss3, libgtk, libgbm, the
# x11/xcb libs, ...) once per era. This is the slow, bandwidth-heavy step and it is
# IDENTICAL for every Chrome version in the era, so build-chrome-images.sh discovers a
# single era-representative deb from the archive manifest and passes it here for every
# build in the era — keeping this layer cached so a new Chrome version downloads only
# its own deb below. apt self-heals in the final layer if a later Chrome adds a dep.
#
# Deriving deps from a real deb (not a hand-written package list) stays correct across
# Ubuntu's t64 library renames (libasound2 -> libasound2t64, etc.). Empty by default,
# so a bare `docker build` still works — it just skips the pre-warm.
#
# The deb's postinst drops Google's apt source into the image; we delete it here so
# the per-version layer's apt-get update doesn't fail on that unsigned repo.
ARG CHROME_DEPS_DEB_URL=""
ARG CHROME_DEPS_DEB_SHA256=""
RUN set -eux; \
    if [ -n "${CHROME_DEPS_DEB_URL}" ]; then \
      curl -fsSL "${CHROME_DEPS_DEB_URL}" -o /tmp/chrome-deps.deb; \
      if [ -n "${CHROME_DEPS_DEB_SHA256}" ]; then \
        echo "${CHROME_DEPS_DEB_SHA256}  /tmp/chrome-deps.deb" | sha256sum -c -; \
      fi; \
      apt-get update; \
      apt-get install -y --no-install-recommends /tmp/chrome-deps.deb; \
      rm -f /tmp/chrome-deps.deb; \
      rm -f /etc/apt/sources.list.d/google-chrome.list; \
      rm -rf /var/lib/apt/lists/*; \
    fi

# tini isn't packaged for older Ubuntu (e.g. 18.04), so fetch the static release
# binary for a uniform init across every era. amd64 only — the Chrome debs are too.
ARG TINI_VERSION=v0.19.0
ARG TINI_SHA256=c5b0666b4cb676901f90dfcb37106783c5fe2077b04590973b885950611b30ee
RUN set -eux; \
    curl -fsSL "https://github.com/krallin/tini/releases/download/${TINI_VERSION}/tini-static-amd64" -o /usr/local/bin/tini; \
    echo "${TINI_SHA256}  /usr/local/bin/tini" | sha256sum -c -; \
    chmod +x /usr/local/bin/tini

# Non-root runtime user. Do NOT chown /opt/google/chrome — that would clobber the
# SUID bit on chrome-sandbox.
RUN groupadd -r chrome && \
    useradd -r -g chrome -G audio,video -m -d /home/chrome chrome

COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Per-Chrome-version layer — the only one that re-runs per version. Its dependency
# closure is already installed above, so apt fetches just the Chrome deb itself
# (plus any dep a newer Chrome added). The ARGs live here so a new URL invalidates
# only this layer and the cheap metadata below.
ARG CHROME_DEB_URL
ARG CHROME_DEB_SHA256=""
RUN set -eux; \
    test -n "${CHROME_DEB_URL}"; \
    curl -fsSL "${CHROME_DEB_URL}" -o /tmp/chrome.deb; \
    if [ -n "${CHROME_DEB_SHA256}" ]; then \
      echo "${CHROME_DEB_SHA256}  /tmp/chrome.deb" | sha256sum -c -; \
    fi; \
    apt-get update; \
    apt-get install -y --no-install-recommends /tmp/chrome.deb; \
    rm -f /tmp/chrome.deb; \
    rm -rf /var/lib/apt/lists/*; \
    # Sanity: the sandbox helper must stay root:root 4755 for CHROME_SANDBOX=on. \
    ls -l /opt/google/chrome/chrome-sandbox

USER chrome
WORKDIR /home/chrome
EXPOSE 9222

HEALTHCHECK --interval=10s --timeout=3s --start-period=15s --retries=5 \
  CMD curl -fsS "http://127.0.0.1:${CHROME_DEBUG_PORT:-9222}/json/version" >/dev/null || exit 1

ENTRYPOINT ["/usr/local/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
